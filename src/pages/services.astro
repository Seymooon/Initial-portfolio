---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Services">

<section class="services-page">

  <!-- ================= INTRO ================= -->

  <div class="intro">

    <p class="eyebrow">
      Virtual Assistant
    </p>

    <h1>
      Services
    </h1>

    <p class="description">
      Structured virtual assistant support focused on communication,
      organization, and reliability.
    </p>

  </div>

  <!-- ================= SERVICES ================= -->

  <div class="services-list">

    <!-- BASIC -->
    <details class="service-card">

      <summary>
        <div class="left">
          <p class="service-number">01</p>
          <h2>Basic Support</h2>
        </div>

        <span class="service-pill">More info</span>
      </summary>

      <div class="service-content">
        <div class="service-inner">

          <h3>Inbox & Communication Management</h3>
          <p>
            Handles emails and messages in an organized and professional way so nothing is missed.
          </p>

          <h3>Calendar & Scheduling Support</h3>
          <p>
            Manages appointments, meetings, reminders, and scheduling to keep your day organized.
          </p>

        </div>
      </div>

    </details>

    <!-- OPERATIONS -->
    <details class="service-card">

      <summary>
        <div class="left">
          <p class="service-number">02</p>
          <h2>Operations Support</h2>
        </div>

        <span class="service-pill">More info</span>
      </summary>

      <div class="service-content">
        <div class="service-inner">

          <h3>Task & Workflow Assistance</h3>
          <p>
            Organizing workflows and managing tasks using productivity tools like Google Workspace.
          </p>

          <h3>Recruitment Coordination</h3>
          <p>
            Supports scheduling, screening, follow-ups, and candidate coordination.
          </p>

        </div>
      </div>

    </details>

    <!-- BUSINESS -->
    <details class="service-card">

      <summary>
        <div class="left">
          <p class="service-number">03</p>
          <h2>Business Support</h2>
        </div>

        <span class="service-pill">More info</span>
      </summary>

      <div class="service-content">
        <div class="service-inner">

          <h3>Social Media Assistance</h3>
          <p>
            Content planning, scheduling, and engagement support.
          </p>

          <h3>Client Outreach</h3>
          <p>
            Professional outreach and follow-ups via email and messaging platforms.
          </p>

        </div>
      </div>

    </details>

  </div>

</section>

<!-- ================= STYLES ================= -->

<style>

.services-page{
  max-width:1100px;
  margin:auto;
  padding:6rem 1.5rem 5rem;
}

/* INTRO */

.intro{
  max-width:720px;
}

.eyebrow{
  font-size:.8rem;
  text-transform:uppercase;
  letter-spacing:.3em;
  color:#7a8b78;
}

.intro h1{
  margin-top:.4rem;
  font-family:serif;
  font-size:3.6rem;
  font-weight:600;
  color:#2f3a2f;
}

.description{
  margin-top:1rem;
  line-height:1.9;
  max-width:620px;
  color:#6b6b6b;
}

/* LIST */

.services-list{
  margin-top:4rem;
  display:flex;
  flex-direction:column;
  gap:18px;
}

/* CARD */

.service-card{
  border:1px solid #e7e1d6;
  border-radius:22px;
  background:#faf7f2;
  overflow:hidden;
}

/* SUMMARY */

.service-card summary{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:26px;
  cursor:pointer;
  list-style:none;
}

.service-card summary::-webkit-details-marker{
  display:none;
}

.left{
  display:flex;
  flex-direction:column;
  gap:6px;
}

.service-number{
  font-size:.75rem;
  letter-spacing:.3em;
  text-transform:uppercase;
  color:#7a8b78;
}

.service-card h2{
  font-size:1.6rem;
  font-weight:600;
  color:#2f3a2f;
}

.service-pill{
  border:1px solid #6f7f6a;
  border-radius:999px;
  padding:8px 16px;
  font-size:.75rem;
  color:#6f7f6a;
}

/* DROPDOWN */

.service-content{
  display:grid;
  grid-template-rows:0fr;
  transition:grid-template-rows .45s ease;
}

.service-inner{
  overflow:hidden;
  padding:0 26px;
}

.service-card[open] .service-content{
  grid-template-rows:1fr;
}

.service-card[open] .service-inner{
  padding:0 26px 26px;
}

/* OPEN STATE */

.service-card[open]{
  background:#6f7f6a;
}

.service-card[open] .service-number,
.service-card[open] h2{
  color:#f6f2ea;
}

.service-card[open] .service-pill{
  background:#f6f2ea;
  color:#2f3a2f;
}

/* TEXT HIERARCHY FIX */

.service-inner h3{
  margin-top:18px;
  font-size:15px;
  font-weight:700;
  color:#f6f2ea;   /* white + bold */
}

.service-inner p{
  margin-top:6px;
  line-height:1.8;
  font-weight:400; /* normal */
  color:#f6f2ea;   /* white */
  opacity:0.9;     /* softer hierarchy */
}

/* MOBILE */

@media (max-width:768px){

  .intro h1{
    font-size:3rem;
  }

  .service-card summary{
    padding:20px;
    align-items:flex-start;
    gap:14px;
  }

  .service-card h2{
    font-size:1.3rem;
  }

}

</style>

</MainLayout>