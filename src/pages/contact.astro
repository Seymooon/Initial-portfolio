---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Contact">

<section class="min-h-screen bg-[#f6f2ea] text-[#3f4a3a] px-6 md:px-16 py-20">

  <div class="max-w-5xl mx-auto">

    <!-- HEADER -->
    <h1 class="text-4xl md:text-5xl font-serif font-semibold text-[#2f3a2f]">
      Contact
    </h1>

    <p class="mt-4 max-w-2xl text-zinc-600 leading-7">
      Have a project in mind or need reliable virtual assistant support. I would love to hear from you and help keep your workflow organized and efficient.
    </p>

    <!-- BUTTONS -->
    <div class="mt-10 flex flex-wrap gap-4">

      <a
        href="mailto:johnsimongutang@gmail.com"
        class="btn-primary"
      >
        Email me
      </a>

      <a
        href="https://www.linkedin.com/in/john-simon-gutang-5aab77234/"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-secondary"
      >
        LinkedIn →
      </a>

    </div>

    <!-- EMAIL BLOCK -->
    <div class="mt-14">

  <p class="text-sm text-zinc-500">
    Or save my email for later
  </p>

  <p class="mt-2 text-2xl font-light text-[#3f4a3a]">
    johnsimongutang@gmail.com
  </p>

</div>

  </div>

</section>

<style>

  .card{
    background: #faf7f2;
    border: 1px solid #e7e1d6;
    border-radius: 16px;
    padding: 22px;
    transition: all 0.3s ease;
  }

  .card:hover{
    background: #f3efe6;
    transform: translateY(-4px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.06);
  }

  .btn-primary{
    background: #6f7f6a;
    color: #f6f2ea;
    padding: 12px 22px;
    border-radius: 999px;
    transition: all 0.3s ease;
  }

  .btn-primary:hover{
    transform: translateY(-2px);
    opacity: 0.9;
  }

  .btn-secondary{
    border: 1px solid #6f7f6a;
    color: #6f7f6a;
    padding: 12px 22px;
    border-radius: 999px;
    transition: all 0.3s ease;
  }

  .btn-secondary:hover{
    background: #6f7f6a;
    color: #f6f2ea;
    transform: translateY(-2px);
  }

</style>

</MainLayout>